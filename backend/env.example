DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname

GEMINI_API_KEY=

# Gmail: same OAuth app for reading inbox + sending replies (users.messages.send)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# Required for Pub/Sub push mode (Gmail users.watch -> Pub/Sub topic)
# Format: projects/PROJECT_ID/topics/TOPIC_NAME
GMAIL_PUBSUB_TOPIC=

# Optional but recommended: protect /api/webhooks/gmail/pubsub and /api/gmail/watch endpoints
GMAIL_WEBHOOK_SECRET=

# Auto-poll unread Gmail inbox messages and push them to Kafka intake.
# Keep enabled in local/dev if Pub/Sub is not configured.
GMAIL_POLL_ENABLED=true
GMAIL_POLL_INTERVAL_SECONDS=30

BUSINESS_NAME=Softech Global Services
BUSINESS_FOCUS=ERP solution services, ERPNext implementation, AI MCP integration with ERP systems, AI automation, and AI agent solutions for business operations.

KAFKA_BOOTSTRAP_SERVERS=localhost:29092
KAFKA_INTAKE_TOPIC=fte.inbound
KAFKA_CONSUMER_GROUP=fte-message-processor

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

CORS_ORIGINS=http://localhost:3000

# Admin portal credentials (used by /api/admin/* and /api/reports/* routes)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=adminpass
