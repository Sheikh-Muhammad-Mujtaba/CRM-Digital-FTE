# Database
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname

# AI
GEMINI_API_KEY=

# Business profile (optional overrides)
BUSINESS_NAME=NexTech Services Group
BUSINESS_FOCUS=managed IT, cloud, networking, security, and technical consulting for organizations.

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:29092
KAFKA_INTAKE_TOPIC=fte.inbound
KAFKA_CONSUMER_GROUP=fte-message-processor

# Outbound — email (web form replies + Gmail-style email channel)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-account@gmail.com
SMTP_PASSWORD=app-specific-password
SMTP_FROM=your-account@gmail.com
SMTP_USE_TLS=true
SUPPORT_EMAIL_SUBJECT_PREFIX=[NexTech Support]

# Outbound — WhatsApp (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# API
CORS_ORIGINS=http://localhost:3000
